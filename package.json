{
  "name": "app_name",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.12",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "start": "turbo run start",
    "start:api": "turbo run start --filter=api",
    "start:web": "turbo run start --filter=web",
    "check-types": "turbo run check-types",
    "test": "bun test",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "db:generate": "bun run --filter=@repo/db db:generate",
    "db:migrate": "bun run --filter=@repo/db db:migrate",
    "db:push": "bun run --filter=@repo/db db:push",
    "db:studio": "bun run --filter=@repo/db db:studio",
    "docker:build:api": "docker build -f apps/api/Dockerfile -t app_name-api:local .",
    "docker:run:api": "docker run --rm -p 3000:3000 --env-file apps/api/.env app_name-api:local",
    "docker:shell:api": "docker run --rm -it --entrypoint sh app_name-api:local"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/bun": "latest",
    "turbo": "^2.8.17",
    "typescript": "^6"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
